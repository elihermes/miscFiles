<script>
    document.addEventListener('DOMContentLoaded', function() {
        const versionStamp = document.getElementById('versionStamp');
        const versionUpdatedAt = document.getElementById('versionUpdatedAt');
        if (versionStamp) {
            versionStamp.title = 'עודכן לאחרונה';
        }

        const modified = new Date(document.lastModified);
        if (!Number.isNaN(modified.getTime()) && versionUpdatedAt) {
            const pad = (n) => String(n).padStart(2, '0');

            // Mask the calendar date into a short code so date details are not exposed.
            const year = modified.getFullYear();
            const month = modified.getMonth() + 1;
            const day = modified.getDate();
            const seed = (year * 372) + (month * 31) + day + 157;
            const codeNum = (seed * 73) % 46656;
            const dateCode = codeNum.toString(36).toUpperCase().padStart(3, '0');

            const hours = pad(modified.getHours());
            const minutes = pad(modified.getMinutes());
            const seconds = pad(modified.getSeconds());

            versionUpdatedAt.textContent = `${dateCode} ${hours}:${minutes}:${seconds}`;
        }

        const openQuestionModalBtn = document.getElementById('openQuestionModalBtn');
        const closeQuestionModalBtn = document.getElementById('closeQuestionModalBtn');
        const questionModal = document.getElementById('questionModal');

        function openQuestionModal() {
            questionModal.classList.add('is-open');
            document.body.classList.add('modal-open');
        }

        function closeQuestionModal() {
            questionModal.classList.remove('is-open');
            document.body.classList.remove('modal-open');
        }

        openQuestionModalBtn.addEventListener('click', openQuestionModal);
        closeQuestionModalBtn.addEventListener('click', closeQuestionModal);

        questionModal.addEventListener('click', function(event) {
            if (event.target === questionModal) {
                closeQuestionModal();
            }
        });

        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape' && questionModal.classList.contains('is-open')) {
                closeQuestionModal();
            }
        });
    });
</script>

</body>
</html>