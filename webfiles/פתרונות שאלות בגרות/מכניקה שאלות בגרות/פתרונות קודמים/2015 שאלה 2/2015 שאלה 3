        .version-stamp {
            display: inline-flex;
            align-items: center;
            gap: 0.35rem;
            padding: 0.28rem 0.55rem;
            border-radius: 9999px;
            border: 1px solid #bfdbfe;
            background: rgba(239, 246, 255, 0.95);
            color: #1e3a8a;
            font-size: 0.72rem;
            font-weight: 600;
